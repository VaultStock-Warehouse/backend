# =============================================
# Root .env — copy to .env and fill in values
# =============================================

# PostgreSQL (used by docker-compose-backend-local.yml)
POSTGRES_USER=warehouse_user
POSTGRES_PASSWORD=warehouse_pass
POSTGRES_DB=warehouse_db

# Backend
DATABASE_URL=postgresql://warehouse_user:warehouse_pass@postgres:5432/warehouse_db
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d
NODE_ENV=production

# Frontend
VITE_API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Cloud DB (only needed for docker-compose-backend-cloud.yml)
# DATABASE_URL=postgresql://user:password@your-cloud-host:5432/dbname
# DB_HOST=your-cloud-host
# DB_PORT=5432
